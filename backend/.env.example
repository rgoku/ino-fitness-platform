# Backend Environment Configuration
# Copy this to .env and fill in your values

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/ino_fitness
# For SQLite (development): DATABASE_URL=sqlite:///./test.db

# Security
SECRET_KEY=your-super-secret-key-change-this-for-production
JWT_EXPIRATION_HOURS=24

# AI Service
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Payment Processing
STRIPE_SECRET_KEY=sk_test_your-key-here
STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here
STRIPE_PRICE_STARTER=price_starter_id_here
STRIPE_PRICE_PRO=price_pro_id_here
STRIPE_PRICE_SCALE=price_scale_id_here

# Redis (for rate limiting + Celery)
REDIS_URL=redis://localhost:6379

# Firebase credentials file path (for mobile auth)
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:8081,exp://localhost:8081,http://localhost:19000

# Email Configuration (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@inofitness.com

# Firebase (for mobile auth)
FIREBASE_API_KEY=your-firebase-key
FIREBASE_PROJECT_ID=your-project-id

# Environment
ENVIRONMENT=development
DEBUG=True

# API
API_VERSION=v1
API_PREFIX=/api
