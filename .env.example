# Environment configuration example for INÖ Fitness Backend
# Copy this file to .env and fill in your actual values

# Database
DATABASE_URL=sqlite:///./ino_fitness.db
# DATABASE_URL=postgresql://user:password@localhost/ino_fitness  # For production

# API & Auth
SECRET_KEY=your-secret-key-here-min-32-chars-recommended
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,*

# Debug Mode
DEBUG=false

# Claude AI
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe (Optional - for payments)
STRIPE_API_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Firebase Cloud Messaging (For push notifications)
FCM_API_KEY=your-fcm-server-api-key-here
FCM_PROJECT_ID=your-firebase-project-id

# SMTP Configuration (For email notifications)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password

# Optional: Sentry for error tracking
SENTRY_DSN=

# Optional: Environment name
ENVIRONMENT=development
