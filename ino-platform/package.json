{
  "name": "ino-platform",
  "private": true,
  "version": "0.1.0",
  "description": "INÖ — Professional coaching platform",
  "scripts": {
    "dev:coach": "pnpm --filter @ino/coach-web dev",
    "dev:fit": "pnpm --filter @ino/fit-mobile start",
    "dev:landing": "pnpm --filter @ino/landing dev",
    "dev:api": "pnpm --filter @ino/api dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
